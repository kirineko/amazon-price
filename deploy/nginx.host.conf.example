# 宿主机 nginx 配置（a.kirineko.tech）
#
# 用法：
#   sudo cp deploy/nginx.host.conf.example /etc/nginx/sites-available/amazon-price
#   sudo ln -sf /etc/nginx/sites-available/amazon-price /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# 申请 HTTPS（certbot 会自动修改本文件，写入 443 与证书，无需手动指定路径）：
#   sudo certbot --nginx -d a.kirineko.tech
#
# 注意：certbot 修改后的 /etc/nginx/sites-available/amazon-price 不要用仓库 example 覆盖。

upstream amazon_price_app {
    server 127.0.0.1:9080;
    keepalive 8;
}

server {
    listen 80;
    server_name a.kirineko.tech;

    client_max_body_size 10m;

    location /api/events {
        proxy_pass http://amazon_price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        chunked_transfer_encoding off;
    }

    location /api/ {
        proxy_pass http://amazon_price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location / {
        proxy_pass http://amazon_price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}
