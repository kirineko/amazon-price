# 阶段 2：HTTP 跳转 + HTTPS（certbot 证书申请完成后使用）
#
# 用法：
#   sudo cp deploy/nginx.host.https.conf.example /etc/nginx/sites-available/amazon-price
#   sudo nginx -t && sudo systemctl reload nginx
#
# 前提：
#   - 证书已存在于 /etc/letsencrypt/live/a.kirineko.tech/
#   - .env 中 SECURE_COOKIES=true，并 docker compose up -d 重启 app

upstream amazon_price_app {
    server 127.0.0.1:9080;
    keepalive 8;
}

server {
    listen 80;
    server_name a.kirineko.tech;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name a.kirineko.tech;

    ssl_certificate     /etc/letsencrypt/live/a.kirineko.tech/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/a.kirineko.tech/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;

    client_max_body_size 10m;

    location /api/events {
        proxy_pass http://amazon_price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        chunked_transfer_encoding off;
    }

    location /api/ {
        proxy_pass http://amazon_price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location / {
        proxy_pass http://amazon_price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }
}
